@model List<FrontendAdministrativo.DTOs.PartidoDTO>
@{
    ViewData["Title"] = "Partidos";
    string filtroEstado = ViewBag.FiltroEstado ?? "";
    string filtroFase   = ViewBag.FiltroFase ?? "";
}

<!-- ══ PARTIDOS INDEX ═══════════════════════════════════════ -->

<!-- Encabezado -->
<div class="page-header">
    <div>
        <h1>🏟️ Partidos</h1>
        <p>Gestión de partidos del Mundial de Fútbol 2026</p>
    </div>
    <a asp-action="Create" class="btn-admin btn-admin-primary">
        <i class="bi bi-plus-lg"></i> Nuevo partido
    </a>
</div>

<!-- ── Filtros ──────────────────────────────────────────────── -->
<form method="get" asp-action="Index">
    <div class="filter-bar">
        <span class="filter-label"><i class="bi bi-funnel me-1"></i>Filtros:</span>

        <!-- Búsqueda libre -->
        <input type="text"
               id="busquedaTabla"
               class="form-control-admin"
               placeholder="Buscar equipo o sede..."
               style="max-width:220px;"
               value="" />

        <!-- Filtro por estado -->
        <select name="filtroEstado" class="form-control-admin" style="max-width:160px;"
                onchange="this.form.submit()">
            <option value="" selected="@(string.IsNullOrEmpty(filtroEstado))">Todos los estados</option>
            <option value="Pendiente"  selected="@(filtroEstado == "Pendiente")">⏳ Pendiente</option>
            <option value="EnCurso"    selected="@(filtroEstado == "EnCurso")">🔴 En curso</option>
            <option value="Finalizado" selected="@(filtroEstado == "Finalizado")">✅ Finalizado</option>
        </select>

        <!-- Filtro por fase -->
        <select name="filtroFase" class="form-control-admin" style="max-width:180px;"
                onchange="this.form.submit()">
            <option value="" selected="@(string.IsNullOrEmpty(filtroFase))">Todas las fases</option>
            @foreach (var fase in (List<string>)ViewBag.Fases)
            {
                <option value="@fase" selected="@(filtroFase == fase)">@fase</option>
            }
        </select>

        @if (!string.IsNullOrEmpty(filtroEstado) || !string.IsNullOrEmpty(filtroFase))
        {
            <a asp-action="Index" class="btn-admin btn-admin-secondary btn-admin-sm">
                <i class="bi bi-x"></i> Limpiar
            </a>
        }

        <span class="ms-auto" style="font-size:12px;color:var(--text-muted);">
            @Model.Count resultado(s)
        </span>
    </div>
</form>

<!-- ── Tabla de partidos ─────────────────────────────────────── -->
<div class="admin-card p-0">
    <div class="table-responsive">
        <table class="admin-table" id="tablaPartidos">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Local</th>
                    <th>Visitante</th>
                    <th>Resultado</th>
                    <th>Fase</th>
                    <th>Fecha y Hora</th>
                    <th>Sede</th>
                    <th>Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="9" class="text-center py-5" style="color:var(--text-muted);">
                            <div style="font-size:40px;">🏟️</div>
                            <div class="mt-2">No hay partidos registrados.</div>
                            <a asp-action="Create" class="btn-admin btn-admin-primary btn-admin-sm mt-3">
                                + Crear primer partido
                            </a>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var partido in Model)
                    {
                        <tr>
                            <td style="color:var(--text-muted);font-size:12px;">#@partido.Id</td>

                            <td>
                                <span style="font-weight:600;">@partido.SeleccionLocal</span>
                            </td>

                            <td>
                                <span style="font-weight:600;">@partido.SeleccionVisitante</span>
                            </td>

                            <td>
                                @if (partido.GolesLocal.HasValue && partido.GolesVisitante.HasValue)
                                {
                                    <span class="score-display">
                                        <span class="score-value">@partido.GolesLocal</span>
                                        <span class="score-sep">-</span>
                                        <span class="score-value">@partido.GolesVisitante</span>
                                    </span>
                                }
                                else
                                {
                                    <span style="color:var(--text-muted);">—</span>
                                }
                            </td>

                            <td style="font-size:12px;">@partido.Fase</td>

                            <td style="font-size:12px;white-space:nowrap;">
                                <i class="bi bi-calendar3 me-1" style="color:var(--text-muted);"></i>
                                @partido.FechaFormateada
                            </td>

                            <td style="font-size:12px;">
                                <span title="@partido.Sede">
                                    @(partido.Sede.Length > 22 ? partido.Sede.Substring(0, 22) + "…" : partido.Sede)
                                </span>
                            </td>

                            <td>
                                @{
                                    string badgeClass = partido.Estado switch {
                                        "Finalizado" => "badge-estado badge-finalizado",
                                        "EnCurso"    => "badge-estado badge-en-curso",
                                        _            => "badge-estado badge-pendiente"
                                    };
                                }
                                <span class="@badgeClass">@partido.Estado</span>
                            </td>

                            <td>
                                <div class="d-flex gap-1 justify-content-center flex-wrap">

                                    <!-- Ver detalles -->
                                    <a asp-action="Details" asp-route-id="@partido.Id"
                                       class="btn-admin btn-admin-secondary btn-admin-sm"
                                       title="Ver detalle">
                                        <i class="bi bi-eye"></i>
                                    </a>

                                    <!-- Editar -->
                                    <a asp-action="Edit" asp-route-id="@partido.Id"
                                       class="btn-admin btn-admin-secondary btn-admin-sm"
                                       title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    <!-- Registrar resultado -->
                                    @if (partido.Estado != "Finalizado")
                                    {
                                        <a asp-action="RegistrarResultado" asp-route-id="@partido.Id"
                                           class="btn-admin btn-admin-sm"
                                           style="background:rgba(40,167,69,0.15);color:#28a745;"
                                           title="Registrar resultado">
                                            <i class="bi bi-trophy"></i>
                                        </a>
                                    }

                                    <!-- Eliminar -->
                                    <form asp-action="Delete" asp-route-id="@partido.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="btn-admin btn-admin-sm"
                                                style="background:rgba(220,53,69,0.15);color:#dc3545;"
                                                title="Eliminar"
                                                onclick="confirmarEliminar(event, '@partido.SeleccionLocal vs @partido.SeleccionVisitante')">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </form>

                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- Sin resultados de búsqueda local -->
    <div id="sinResultados" class="text-center py-4" style="display:none;color:var(--text-muted);">
        <i class="bi bi-search fs-3"></i>
        <div class="mt-2">No se encontraron partidos con ese criterio.</div>
    </div>
</div>
