@model FrontendAdministrativo.DTOs.UsuarioDTO
@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="page-header">
    <div>
        <h1>✏️ Editar Usuario</h1>
        <p>Modifique los datos del usuario</p>
    </div>
    <a asp-action="Index" class="btn-admin btn-admin-secondary">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert-admin alert-admin-error mb-3">
        <i class="bi bi-exclamation-triangle-fill"></i>
        @TempData["Error"]
    </div>
}

<div class="admin-card" style="max-width: 600px;">

    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div asp-validation-summary="All" class="alert-admin alert-admin-error mb-3"
             style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")">
        </div>

        <!-- Nombre -->
        <div class="form-group-admin mb-3">
            <label asp-for="Nombre" class="form-label">👤 Nombre</label>
            <input asp-for="Nombre" class="form-control-admin" />
            <span asp-validation-for="Nombre" class="text-danger small"></span>
        </div>

        <!-- Username -->
        <div class="form-group-admin mb-3">
            <label asp-for="Username" class="form-label">🔑 Usuario</label>
            <input asp-for="Username" class="form-control-admin" />
            <span asp-validation-for="Username" class="text-danger small"></span>
        </div>

        <!-- Email -->
        <div class="form-group-admin mb-3">
            <label asp-for="Email" class="form-label">📧 Email</label>
            <input asp-for="Email" class="form-control-admin" />
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>

        <!-- Rol (ahora con SelectListItem) -->
        <div class="form-group-admin mb-3">
            <label asp-for="Rol" class="form-label">🎯 Rol</label>
            <select asp-for="Rol" class="form-control-admin" asp-items="ViewBag.Roles">
                <option value="">-- Seleccione --</option>
            </select>
            <span asp-validation-for="Rol" class="text-danger small"></span>
        </div>

        <!-- Activo -->
        <div class="form-group-admin mb-3">
            <label asp-for="Activo" class="form-label">✅ Estado</label>
            <select asp-for="Activo" class="form-control-admin">
                <option value="true">Activo</option>
                <option value="false">Inactivo</option>
            </select>
            <span asp-validation-for="Activo" class="text-danger small"></span>
        </div>

        <!-- Fecha de Registro (solo lectura) -->
        <div class="form-group-admin mb-3">
            <label class="form-label">📅 Fecha de Registro</label>
            <input class="form-control-admin" value="@Model.FechaRegistro.ToString("dd/MM/yyyy HH:mm")" disabled />
        </div>

        <!-- Botones -->
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn-admin btn-admin-primary">
                <i class="bi bi-check-lg"></i> Guardar cambios
            </button>
            <a asp-action="Index" class="btn-admin btn-admin-secondary">
                <i class="bi bi-x"></i> Cancelar
            </a>
        </div>

    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}