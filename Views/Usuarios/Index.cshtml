@model List<FrontendAdministrativo.DTOs.UsuarioDTO>
@{
    ViewData["Title"] = "Usuarios";
    string filtroRol = ViewBag.FiltroRol ?? "";
    string filtroBusqueda = ViewBag.FiltroBusqueda ?? "";
}

<!-- ══ USUARIOS INDEX ═══════════════════════════════════════ -->

<div class="page-header">
    <div>
        <h1>👥 Usuarios</h1>
        <p>Administración de usuarios registrados en el sistema</p>
    </div>
    <span class="badge-estado badge-activo" style="font-size:13px;padding:8px 16px;">
        @Model.Count usuario(s)
    </span>
</div>

<!-- ── Filtros ──────────────────────────────────────────────── -->
<form method="get" asp-action="Index">
    <div class="filter-bar">
        <span class="filter-label"><i class="bi bi-funnel me-1"></i>Filtros:</span>

        <!-- Búsqueda en tabla (JS, lado cliente) -->
        <input type="text"
               id="busquedaUsuarios"
               class="form-control-admin"
               placeholder="Buscar por nombre o email..."
               style="max-width:260px;" />

        <!-- Búsqueda server-side por rol -->
        <select name="filtroRol" class="form-control-admin" style="max-width:180px;"
                onchange="this.form.submit()">
            <option value="" selected="@(string.IsNullOrEmpty(filtroRol))">Todos los roles</option>
            @if (ViewBag.Roles != null)
            {
                foreach (var rol in (List<string>)ViewBag.Roles)
                {
                    <option value="@rol" selected="@(filtroRol == rol)">@rol</option>
                }
            }
        </select>

        @if (!string.IsNullOrEmpty(filtroRol))
        {
            <a asp-action="Index" class="btn-admin btn-admin-secondary btn-admin-sm">
                <i class="bi bi-x"></i> Limpiar
            </a>
        }
    </div>
</form>

<!-- ── Tabla de usuarios ─────────────────────────────────────── -->
<div class="admin-card p-0">
    <div class="table-responsive">
        <table class="admin-table" id="tablaUsuarios">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nombre</th>
                    <th>Usuario</th>
                    <th>Rol</th>
                    <th>Estado</th>
                    <th>Registro</th>
                    <th>Saldo UTNGolCoin</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center py-5" style="color:var(--text-muted);">
                            <div style="font-size:40px;">👥</div>
                            <div class="mt-2">No hay usuarios registrados.</div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var usuario in Model)
                    {
                        <tr>
                            <td style="color:var(--text-muted);font-size:12px;">#@usuario.Id</td>

                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div style="width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,var(--color-accent),var(--color-accent2));display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;flex-shrink:0;">
                                        @usuario.Nombre.Substring(0, 1).ToUpper()
                                    </div>
                                    <span style="font-weight:600;">@usuario.Nombre</span>
                                </div>
                            </td>

                            <td style="color:var(--text-secondary);font-size:12px;">@usuario.Username</td>

                            <td>
                                @{
                                    string rolNombre = usuario.Rol?.Nombre ?? "Sin rol";
                                    string badgeClass = (rolNombre == "ADMINISTRADOR" || rolNombre == "Administrador")
                                        ? "badge-estado badge-admin"
                                        : "badge-estado badge-usuario";
                                    string rolMostrado = rolNombre == "ADMINISTRADOR" ? "Administrador" :
                                                         rolNombre == "USUARIO" ? "Usuario" :
                                                         rolNombre;
                                }
                                <span class="@badgeClass">
                                    @rolMostrado
                                </span>
                            </td>

                            <td>
                                <span class="badge-estado @(usuario.Activo ? "badge-activo" : "badge-inactivo")">
                                    @(usuario.Activo ? "Activo" : "Inactivo")
                                </span>
                            </td>

                            <td style="font-size:12px;color:var(--text-secondary);">
                                @usuario.FechaRegistro.ToString("dd/MM/yyyy")
                            </td>

                            <td>
                                <span style="font-size:13px;font-weight:700;color:var(--color-gold);">
                                    🪙 @usuario.SaldoUTNGolCoin.ToString("N2")
                                </span>
                            </td>

                            <td>
                                <div class="d-flex gap-1 justify-content-center">
                                    <!-- Recargar Saldo -->
                                    @if (usuario.SaldoUTNGolCoin == 0)
                                    {
                                        <form asp-action="RecargarSaldo" asp-route-id="@usuario.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit"
                                                    class="btn-admin btn-admin-sm"
                                                    style="background:rgba(255, 193, 7, 0.15);color:#ffc107;"
                                                    title="Recargar 1 Moneda"
                                                    onclick="return confirm('¿Recargar 1 UTNGolCoin al usuario @usuario.Nombre?')">
                                                <i class="bi bi-coin"></i> +1
                                            </button>
                                        </form>
                                    }

                                    <!-- Editar -->
                                    <a asp-action="Edit" asp-route-id="@usuario.Id"
                                           class="btn-admin btn-admin-secondary btn-admin-sm"
                                           title="Editar usuario">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    <!-- Eliminar -->
                                    <form asp-action="Delete" asp-route-id="@usuario.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="btn-admin btn-admin-sm"
                                                style="background:rgba(220,53,69,0.15);color:#dc3545;"
                                                title="Eliminar usuario"
                                                onclick="return confirm('¿Eliminar el usuario @usuario.Nombre?')">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- Sin resultados de búsqueda local -->
    <div id="sinResultados" class="text-center py-4" style="display:none;color:var(--text-muted);">
        <i class="bi bi-search fs-3"></i>
        <div class="mt-2">No se encontraron usuarios con ese criterio.</div>
    </div>
</div>

@section Scripts {
    <script>
        // 🔥 BÚSQUEDA EN TIEMPO REAL POR NOMBRE O EMAIL
        document.getElementById('busquedaUsuarios')?.addEventListener('keyup', function() {
            const filter = this.value.toLowerCase();
            const rows = document.querySelectorAll('#tablaUsuarios tbody tr');
            let visible = 0;

            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                const match = text.includes(filter);
                row.style.display = match ? '' : 'none';
                if (match) visible++;
            });

            const noResults = document.getElementById('sinResultados');
            if (noResults) {
                noResults.style.display = visible === 0 ? 'block' : 'none';
            }
        });
    </script>
}